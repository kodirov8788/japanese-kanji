{
  "name": "japanese-kanji",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "stop": "for port in 3000 3001 3002 3003; do echo \"Checking port $port...\"; lsof -ti:$port | xargs kill -9 2>/dev/null || echo \"No process found on port $port\"; done",
    "agent:run": "WORKFLOW_FILE=cursorkleosr/workflow_state.md ts-node tools/next-runner.ts",
    "agent:start": "nohup yarn agent:run > .agent.log 2>&1 & echo $! > .agent.pid && echo \"runner pid: $(cat .agent.pid)\"",
    "agent:status": "test -f .agent.pid && ps -p $(cat .agent.pid) || echo 'not running'",
    "agent:stop": "test -f .agent.pid && kill -9 $(cat .agent.pid) && rm -f .agent.pid || echo 'not running'"
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "next": "15.5.4",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
